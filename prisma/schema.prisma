// prisma/schema.prisma — SquizzGame
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Question {
  id            String   @id @default(cuid())
  question      String   @db.Text
  language      String   @default("fr")        // fr, en, es — langue de référence (legacy mono-langue)
  theme         String                          // general, science, histoire, sport, art, geo, etc.
  difficulty    String   @default("medium")     // easy, medium, hard
  type          String   @default("qcm")        // qcm, pixel, geo

  // QCM (et Pixel — qui est un QCM avec image). En multilingue, l'ordre des
  // options dans chaque traduction DOIT être le même que celui-ci (correctIndex
  // est partagé entre toutes les langues, c'est la SOURCE DE VÉRITÉ).
  options       Json?                           // array of strings (legacy / fallback)
  correctIndex  Int?

  // Pixel — métadonnées d'attribution (Wikimedia / Creative Commons).
  // Présentes en BDD pour rester conformes aux licences CC BY-SA.
  imageUrl      String?
  credit        String?
  creditUrl     String?
  license       String?

  // Geo — la position (lat/lng) est NEUTRE en langue : c'est elle qui sert à
  // la validation, pas le label. Le label/country (legacy) restent en FR.
  lat           Float?
  lng           Float?
  label         String?
  country       String?

  // Métadonnées
  explanation   String   @db.Text
  source        String   @default("manual")    // OpenTriviaDB, ClaudeAPI, manual, admin
  status        String   @default("approved")  // draft, approved, reported, rejected
  sourceRef     String?  @unique               // hash de dédoublonnage pour les imports futurs

  // Stats
  timesShown    Int      @default(0)
  timesCorrect  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  reports       QuestionReport[]
  gameSessions  GameSession[]
  translations  QuestionTranslation[]
  userHistory   UserQuestionHistory[]

  @@index([language])
  @@index([theme])
  @@index([difficulty])
  @@index([type])
}

// Traduction d'une Question dans une langue donnée. La clé business est
// (questionId, language). L'ordre des options DOIT correspondre à
// Question.options / Question.correctIndex (validé serveur côté backfill).
model QuestionTranslation {
  id          String   @id @default(cuid())
  questionId  String
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  language    String                            // fr, en, es
  text        String   @db.Text                 // texte de la question (traduit)
  options     Json?                             // réponses traduites — MÊME ORDRE que correctIndex
  explanation String   @db.Text                 // anecdote traduite
  label       String?                           // géo : nom du lieu traduit
  country     String?                           // géo : pays traduit
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([questionId, language])
  @@index([language])
}

model GameSession {
  id           String    @id @default(cuid())
  roomCode     String    @unique
  playerNames  Json
  settings     Json
  questionIds  Json
  startedAt    DateTime  @default(now())
  endedAt      DateTime?

  questions    Question[]

  @@index([roomCode])
  @@index([startedAt])
}

model QuestionReport {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  // Legacy : champ libre conservé pour ne pas casser d'anciens reports.
  // Les nouveaux signalements utilisent `category` + `comment`.
  reason     String?  @db.Text
  language   String?                                  // version affichée au joueur lors du signalement
  category   String   @default("other")               // translation, wrong_answer, typo, other
  comment    String?  @db.Text                        // texte libre optionnel du joueur
  roomCode   String?
  status     String   @default("open")                // open, resolved
  createdAt  DateTime @default(now())

  @@index([questionId])
  @@index([status])
}

// Joueur authentifié via Google OAuth. La connexion est OPTIONNELLE : les
// joueurs anonymes continuent de jouer sans User. L'identité est reliée au
// jeu/leaderboard/profil (résultats + stats agrégées ci-dessous).
model User {
  id            String   @id @default(cuid())
  googleId      String   @unique
  email         String?
  displayName   String
  avatarUrl     String?
  createdAt     DateTime @default(now())
  lastLoginAt   DateTime @default(now())
  preferredLocale String? // 'fr'|'en'|'es'

  // Pseudo public unique (identité de jeu des comptes connectés). pseudoKey =
  // version normalisée (trim + lower) pour l'unicité insensible à la casse.
  pseudo          String? @unique
  pseudoKey       String? @unique

  // Lien vers les résultats de partie + cache de stats agrégées (mis à jour à
  // chaque fin de partie pour éviter de tout recalculer en lecture).
  results        GamePlayerResult[]
  gamesPlayed    Int      @default(0)
  gamesWon       Int      @default(0)
  totalScore     Int      @default(0)

  // Anti-répétition niveau 2 : questions déjà vues par ce joueur (toutes parties).
  questionHistory UserQuestionHistory[]

  // Signalements de joueurs (modération).
  reportsAgainst  PlayerReport[] @relation("ReportedAgainst")
  reportsMade     PlayerReport[] @relation("ReportsMade")

  @@index([googleId])
  @@index([email])
}

// Signalement d'un joueur par un autre (pseudo / chat / comportement / autre).
// Distinct de QuestionReport. On garde une trace textuelle (pseudo + roomCode)
// même quand le joueur n'est pas certifié.
model PlayerReport {
  id              String   @id @default(cuid())
  reportedUserId  String?
  reportedUser    User?    @relation("ReportedAgainst", fields: [reportedUserId], references: [id], onDelete: SetNull)
  reportedPseudo  String                          // pseudo affiché au moment du signalement
  reporterUserId  String?
  reporter        User?    @relation("ReportsMade", fields: [reporterUserId], references: [id], onDelete: SetNull)
  reporterPseudo  String                          // pseudo affiché de l'auteur
  category        String   @default("other")      // pseudo / chat / behavior / other
  comment         String?  @db.Text               // texte libre (max 500, filtré)
  roomCode        String?
  status          String   @default("open")       // open / resolved
  createdAt       DateTime @default(now())

  @@index([reportedUserId])
  @@index([status])
  @@index([createdAt])
}

// Historique « question vue » par joueur connecté, pour ne pas reservir une
// question avant HISTORY_WINDOW_DAYS jours, à travers TOUTES ses parties.
// Les anonymes (userId absent) n'en génèrent pas.
model UserQuestionHistory {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  seenAt     DateTime @default(now())

  @@unique([userId, questionId])
  @@index([userId, seenAt])
}

// Un résultat de joueur pour une partie terminée (≥2 joueurs). userId est NULL
// pour les anonymes. pseudoKey = pseudo normalisé (pour regrouper l'anonyme dans
// le leaderboard scope=all). C'est la session serveur qui fixe userId, jamais le
// client.
model GamePlayerResult {
  id         String   @id @default(cuid())
  pseudo     String
  pseudoKey  String                          // pseudo normalisé (trim + lower)
  score      Int      @default(0)
  won        Boolean  @default(false)
  roomCode   String?
  createdAt  DateTime @default(now())

  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([pseudoKey])
  @@index([createdAt])
}

model AdminUser {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  role         String    @default("moderator") // admin, moderator
  createdAt    DateTime  @default(now())
  lastLogin    DateTime?

  @@index([username])
}
