// prisma/schema.prisma — SquizzGame
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Question {
  id            String   @id @default(cuid())
  question      String   @db.Text
  language      String   @default("fr")        // fr, en, es — langue de référence (legacy mono-langue)
  theme         String                          // general, science, histoire, sport, art, geo, etc.
  difficulty    String   @default("medium")     // easy, medium, hard
  type          String   @default("qcm")        // qcm, pixel, geo

  // QCM (et Pixel — qui est un QCM avec image). En multilingue, l'ordre des
  // options dans chaque traduction DOIT être le même que celui-ci (correctIndex
  // est partagé entre toutes les langues, c'est la SOURCE DE VÉRITÉ).
  options       Json?                           // array of strings (legacy / fallback)
  correctIndex  Int?

  // Pixel — métadonnées d'attribution (Wikimedia / Creative Commons).
  // Présentes en BDD pour rester conformes aux licences CC BY-SA.
  imageUrl      String?
  credit        String?
  creditUrl     String?
  license       String?

  // Geo — la position (lat/lng) est NEUTRE en langue : c'est elle qui sert à
  // la validation, pas le label. Le label/country (legacy) restent en FR.
  lat           Float?
  lng           Float?
  label         String?
  country       String?

  // Métadonnées
  explanation   String   @db.Text
  source        String   @default("manual")    // OpenTriviaDB, ClaudeAPI, manual, admin
  status        String   @default("approved")  // draft, approved, reported, rejected
  sourceRef     String?  @unique               // hash de dédoublonnage pour les imports futurs

  // Stats
  timesShown    Int      @default(0)
  timesCorrect  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  reports       QuestionReport[]
  gameSessions  GameSession[]
  translations  QuestionTranslation[]

  @@index([language])
  @@index([theme])
  @@index([difficulty])
  @@index([type])
}

// Traduction d'une Question dans une langue donnée. La clé business est
// (questionId, language). L'ordre des options DOIT correspondre à
// Question.options / Question.correctIndex (validé serveur côté backfill).
model QuestionTranslation {
  id          String   @id @default(cuid())
  questionId  String
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  language    String                            // fr, en, es
  text        String   @db.Text                 // texte de la question (traduit)
  options     Json?                             // réponses traduites — MÊME ORDRE que correctIndex
  explanation String   @db.Text                 // anecdote traduite
  label       String?                           // géo : nom du lieu traduit
  country     String?                           // géo : pays traduit
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([questionId, language])
  @@index([language])
}

model GameSession {
  id           String    @id @default(cuid())
  roomCode     String    @unique
  playerNames  Json
  settings     Json
  questionIds  Json
  startedAt    DateTime  @default(now())
  endedAt      DateTime?

  questions    Question[]

  @@index([roomCode])
  @@index([startedAt])
}

model QuestionReport {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  // Legacy : champ libre conservé pour ne pas casser d'anciens reports.
  // Les nouveaux signalements utilisent `category` + `comment`.
  reason     String?  @db.Text
  language   String?                                  // version affichée au joueur lors du signalement
  category   String   @default("other")               // translation, wrong_answer, typo, other
  comment    String?  @db.Text                        // texte libre optionnel du joueur
  roomCode   String?
  status     String   @default("open")                // open, resolved
  createdAt  DateTime @default(now())

  @@index([questionId])
  @@index([status])
}

// Joueur authentifié via Google OAuth. La connexion est OPTIONNELLE : les
// joueurs anonymes continuent de jouer sans User. On ne relie pas encore cette
// identité au lobby/jeu/leaderboard (étape suivante).
model User {
  id            String   @id @default(cuid())
  googleId      String   @unique
  email         String?
  displayName   String
  avatarUrl     String?
  createdAt     DateTime @default(now())
  lastLoginAt   DateTime @default(now())
  // Champs préparés pour les étapes suivantes (succès, profil) — peuplés plus tard
  preferredLocale String? // 'fr'|'en'|'es' au moment de la 1ère connexion

  @@index([googleId])
  @@index([email])
}

model AdminUser {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  role         String    @default("moderator") // admin, moderator
  createdAt    DateTime  @default(now())
  lastLogin    DateTime?

  @@index([username])
}
